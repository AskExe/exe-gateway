# exe-gateway — systemd service unit
# Runs the gateway server outside Docker (direct Node.js on VPS).
#
# Install:
#   cp exe-gateway.service /etc/systemd/system/
#   systemctl daemon-reload
#   systemctl enable --now exe-gateway
#
# Logs:
#   journalctl -u exe-gateway -f
#
# Memory sizing (per adapter account):
#   ~40 MB steady-state (WebSocket + Signal keys + auth)
#   ~200 MB spike during initial history sync (temporary)
#   50 accounts × 40 MB = 2 GB steady + GC + LLM buffers ≈ 6 GB safe
#   Scale: 100 accounts ≈ 8 GB, 200 accounts ≈ 16 GB
#
# DB pool: 50 max connections (sized for 50+ concurrent accounts)
# PostgreSQL should have max_connections >= 200

[Unit]
Description=exe-gateway — multi-platform messaging gateway
Documentation=https://askexe.com
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=exe
Group=exe

# Working directory where exe-gateway is installed
WorkingDirectory=/opt/exe-gateway

# Entry point — Node.js heap sized for 50+ multi-account connections
# 50 accounts: 8 GB heap covers steady-state + history sync spikes + LLM buffers + GC
ExecStart=/usr/bin/node --max-old-space-size=8192 /opt/exe-gateway/dist/bin/exe-gateway.js

# Restart policy — always restart with 5s backoff
Restart=always
RestartSec=5
StartLimitIntervalSec=300
StartLimitBurst=10

# Environment file for secrets (not committed to git)
EnvironmentFile=/opt/exe-gateway/.env

# Logging to journal
StandardOutput=journal
StandardError=journal
SyslogIdentifier=exe-gateway

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/exe/.exe-os
PrivateTmp=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

# Resource limits — sized for 50+ accounts on a 32 GB VPS
# Gateway: 12G max, leaving ~20G for PostgreSQL, OS, and other services
LimitNOFILE=65536
MemoryMax=12G

[Install]
WantedBy=multi-user.target
