{
  "name": "@askexenow/exe-gateway",
  "version": "0.2.1",
  "description": "Standalone webhook server + messaging gateway for multi-platform bot deployment",
  "type": "module",
  "main": "dist/gateway.js",
  "bin": {
    "exe-gateway": "dist/bin/exe-gateway.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin/exe-gateway.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@libsql/client": "^0.14.0",
    "@slack/socket-mode": "^2.0.0",
    "@slack/web-api": "^7.0.0",
    "@whiskeysockets/baileys": "^6.7.0",
    "discord.js": "^14.16.0",
    "grammy": "^1.30.0",
    "nodemailer": "^6.9.0",
    "openai": "^4.70.0",
    "pg": "^8.20.0",
    "socks-proxy-agent": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AskExe/exe-gateway.git"
  },
  "private": false,
  "license": "MIT"
}
