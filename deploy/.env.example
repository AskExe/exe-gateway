NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=2048

EXE_GATEWAY_HOME=/home/exe/.exe-os
EXE_GATEWAY_CONFIG=/home/exe/.exe-os/gateway.json
EXE_GATEWAY_AUTH_TOKEN=replace-with-a-random-hex-token
EXE_GATEWAY_WHATSAPP_VERIFY_TOKEN=

EXE_GATEWAY_WS_RELAY_ENABLED=false
EXE_GATEWAY_WS_RELAY_HOST=127.0.0.1
EXE_GATEWAY_WS_RELAY_PORT=3101
EXE_GATEWAY_WS_RELAY_AUTH_TOKEN=

EXE_GATEWAY_DB_HOST=127.0.0.1
EXE_GATEWAY_DB_PORT=5432
EXE_GATEWAY_DB_USER=
EXE_GATEWAY_DB_PASSWORD=
EXE_GATEWAY_DB_NAME=

ANTHROPIC_API_KEY=
CRM_API_TOKEN=
CRM_GRAPHQL_URL=
WHATSAPP_PROXY_URL=
