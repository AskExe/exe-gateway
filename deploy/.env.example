# exe-gateway environment configuration
# Copy to ~/.exe-os/gateway.json or set as environment variables.

# --- Server ---
PORT=3100
WS_PORT=3101
HOST=0.0.0.0

# --- WhatsApp (Baileys) ---
# WHATSAPP_ENABLED=true
# WHATSAPP_AUTH_DIR=~/.exe-os/.auth/whatsapp

# --- Telegram (Grammy) ---
# TELEGRAM_ENABLED=true
# TELEGRAM_BOT_TOKEN=

# --- Discord (discord.js) ---
# DISCORD_ENABLED=true
# DISCORD_BOT_TOKEN=
# DISCORD_APPLICATION_ID=

# --- Slack (Web API + Socket Mode) ---
# SLACK_ENABLED=true
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# --- Email (Nodemailer SMTP) ---
# EMAIL_ENABLED=true
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=bot@example.com

# --- Webchat (HTTP) ---
# WEBCHAT_ENABLED=true

# --- Webhook (Generic HTTP) ---
# WEBHOOK_ENABLED=true

# --- LLM Providers ---
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# --- Licensing ---
# EXE_LICENSE_KEY=
