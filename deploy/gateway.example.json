{
  "port": 3100,
  "host": "127.0.0.1",
  "whatsappVerifyToken": "set-via-EXE_GATEWAY_WHATSAPP_VERIFY_TOKEN",
  "readOnly": false,
  "storageFilter": {
    "enabled": false
  },
  "wsRelay": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 3101
  },
  "adapters": {
    "whatsapp": {
      "enabled": true,
      "credentials": {
        "app_secret": "set-if-you-use-meta-whatsapp-webhooks"
      },
      "accounts": [
        {
          "name": "default",
          "authDir": "/home/exe/.exe-os/.auth/whatsapp-default"
        }
      ]
    },
    "telegram": {
      "enabled": false,
      "accounts": [
        {
          "name": "default",
          "bot_token": "123456:ABC-DEF...",
          "secret_token": "set-if-you-use-telegram-webhooks"
        }
      ]
    },
    "discord": {
      "enabled": false,
      "accounts": [
        {
          "name": "default",
          "bot_token": "your-discord-token",
          "public_key": "set-if-you-use-discord-interactions"
        }
      ]
    },
    "slack": {
      "enabled": false,
      "accounts": []
    },
    "email": {
      "enabled": false,
      "accounts": []
    }
  }
}
